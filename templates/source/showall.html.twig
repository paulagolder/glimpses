{# templates/source/showall.html.twig #}


{% extends 'base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<link href="{{ asset('css/source.css') }}" rel="stylesheet" />

{% endblock %}

{% block js %}
{{ parent() }}

{% endblock %}

{% block body %}
<div id="source" >

    <div class="heading">
      <div class="title"> Sources</div>
       <div class='returnbutton  '>
                   <a  href = "/source/new" >New Source</a>
               </div>
      </div>
        <form  action="/source/setfilter">
        <div class="row">
         <div class="label"> Filter</div>
         <input type="text" name="filter" value="{{filter}}" >
         <input type="submit" value="action" >
         </div>
         </form>

     <div class= "sourcelist">
    {% for source in sources %}
    <div class= "source">
        <div class="row ">
           {% dump source %}
             <div class="returnbutton col1">   <a   href = "/source/show/{{source.sourceid}}" >view </a> </div>
            <div class= "col2">{{source.sourceId}}</div>
            <div class= "col3"> {{source.title}}</div>
            <div class= "col4"> {{source.region}}</div>
            <div class= "col5"> {{source.period}} </div>
        </div>
        </div>


    {% endfor %}
       </div>

</div>


{% endblock %}


